{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "modulePaths": ["<rootDir>/.."],
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "<rootDir>/../src/**/*.(t|j)s",
    "!<rootDir>/../src/**/*.module.ts",
    "!<rootDir>/../src/**/*.schema.ts",
    "!<rootDir>/../src/**/main.ts",
    "!<rootDir>/../src/**/*.grpc-controller.ts",
    "!<rootDir>/../src/infra/**/*"
  ]
}
